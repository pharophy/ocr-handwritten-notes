# ============================================================================
# HAI Proxy with OpenAI Configuration
# ============================================================================
# Pre-configured for testing OpenAI models via HAI proxy
# Use with: cp .env.proxy.openai .env

AI_PROVIDER=hai-openai

# ============================================================================
# OpenAI Models (Latest from SAP AI LLM Proxy)
# ============================================================================
# Recommended models for each operation:
AI_MODEL_OCR=gpt-5
AI_MODEL_SUMMARIZATION=gpt-5-mini
AI_MODEL_VALIDATION=gpt-5-mini

# Available OpenAI models for OCR (vision required):
# - gpt-5            (latest, best accuracy)
# - gpt-5-mini       (fast, cost-effective)
# - gpt-4.1          (high capability)
# - gpt-4.1-mini     (balanced option)

# ============================================================================
# HAI Proxy Settings
# ============================================================================
HAI_AUTO_START=true
HAI_PROXY_PORT=6655
OPENAI_BASE_URL=http://localhost:6655/openai/v1

# Note: OpenAI via HAI proxy doesn't need OPENAI_API_KEY
# The proxy handles authentication automatically

# ============================================================================
# Handwriting Reference
# ============================================================================
HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
