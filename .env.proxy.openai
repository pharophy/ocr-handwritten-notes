# ============================================================================
# HAI Proxy Configuration - OpenAI Primary (Recommended)
# ============================================================================
# Based on experiments/003-hai-proxy-compatible/ findings
# GPT-5 Mini: 91.2% accuracy at $0.02/image (best tested configuration)
#
# Use with: cp .env.proxy.openai .env
#
# SETUP REQUIREMENTS:
# 1. HAI CLI (Recommended) - Auto-configures authentication
#    - Install: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/recipes/cline/
#    - Authenticate: hai auth login
#    - This config will auto-start proxy when needed
#
# 2. HAI Desktop Application - Requires manual API key
#    - Set HAI_AUTO_START=false (see below)
#    - Start proxy from desktop app
#    - Copy API key from app settings and uncomment/set HAI_API_KEY below:
#    # HAI_API_KEY=your-api-key-from-hai-desktop-app

AI_PROVIDER=hai

# ============================================================================
# Models - EXPERIMENT-VALIDATED (Recommended Configuration)
# ============================================================================
# Based on experiments/003-hai-proxy-compatible/findings.md

# Primary OCR: GPT-5 Mini (Winner from experiments)
# - 91.2% accuracy (highest of all tested models)
# - $0.02/image (83% cheaper than Claude Sonnet)
# - 51.6s latency
# - 0% uncertainty markers (confident output)
# - Score: 75.7/100 (best overall)
AI_MODEL_OCR=gpt-5-mini

# Fallback OCR: GPT-4.1 Mini (Cost-effective cross-provider fallback)
# - 85.6% accuracy
# - $0.02/image (same cost as primary)
# - 39.7s latency (fastest tested)
AI_MODEL_OCR_FALLBACK=gpt-4.1-mini

# Summarization: Claude Haiku (fast, cost-effective)
AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku
AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# ============================================================================
# Alternative OpenAI Models (tested but not recommended for production)
# ============================================================================
# GPT-5 (full model):
# - 82.3% accuracy (9% WORSE than Mini!)
# - $0.10/image (5x more expensive than Mini)
# - 55.4s latency (slower than Mini)
# - Score: 57.6/100
# ❌ Not recommended: Mini outperforms at 1/5th the cost

# GPT-4.1 (full model):
# - Vision not supported in HAI proxy
# ❌ Cannot be used for OCR

# Models NOT available in HAI proxy:
# ❌ gpt-4o - Does not exist (discovered in experiments/001)
# ❌ gpt-4-vision-preview - Not supported (tested in experiments/002)

# ============================================================================
# Why GPT-5 Mini? (Counterintuitive Discovery)
# ============================================================================
# Experiment 003 revealed that mini models outperform full models for OCR:
#
# GPT-5 Mini: 91.2% accuracy at $0.02/image ✅
# GPT-5:      82.3% accuracy at $0.10/image ❌ (worse AND more expensive!)
#
# Possible reasons:
# - Task-specific fine-tuning for vision/OCR tasks
# - Better calibrated confidence (fewer false italic markers)
# - Less prone to over-reasoning on ambiguous handwriting
#
# See: experiments/003-hai-proxy-compatible/findings.md

# ============================================================================
# Performance vs Previous Configuration
# ============================================================================
# Before (Claude Sonnet):  90.3% accuracy, $0.12/image, 52.6s
# After (GPT-5 Mini):      91.2% accuracy, $0.02/image, 51.6s
#
# Improvements:
# - Accuracy:  +0.9 percentage points
# - Cost:      -83% ($0.10 savings per image)
# - Latency:   -1.9% (1 second faster)
# - Score:     +19.8% (75.7 vs 63.2)
#
# Annual Savings (10K images): $1,000/year

# ============================================================================
# HAI Proxy Settings
# ============================================================================
# For HAI CLI users (auto-configured auth):
HAI_AUTO_START=true
HAI_PROXY_PORT=6655

# For HAI Desktop App users (manual auth required):
# HAI_AUTO_START=false
# HAI_API_KEY=your-api-key-from-hai-desktop-app
# HAI_PROXY_PORT=6655

# Note: HAI proxy automatically routes to the correct endpoint based on model name
# - anthropic--* models → /anthropic/ endpoint
# - gpt-* models → /openai/v1 endpoint

# ============================================================================
# OCR Quality Assessment (Enhanced Detection)
# ============================================================================
# Triggers fallback when primary OCR quality is poor
OCR_UNCERTAIN_THRESHOLD=30                   # Combined illegible + italic markers
OCR_CONSECUTIVE_ILLEGIBLE_THRESHOLD=5       # Consecutive illegibles
OCR_LEGACY_QUALITY_CHECK=false               # Use enhanced detection

# ============================================================================
# Image Compression (GPT Models Support 20MB)
# ============================================================================
IMAGE_COMPRESSION_ENABLED=true
IMAGE_COMPRESSION_MAX_SIZE_MB=20             # GPT supports larger than Claude (5MB)
IMAGE_COMPRESSION_MIN_QUALITY=70

# ============================================================================
# Handwriting Reference (Optional)
# ============================================================================
HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
