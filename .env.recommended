# ============================================================================
# RECOMMENDED PRODUCTION CONFIGURATION (Based on Experiments)
# ============================================================================
# Based on comprehensive testing in experiments/003-hai-proxy-compatible/
# Winner: GPT-5 Mini - 91.2% accuracy at $0.02/image (83% cost savings)
#
# Use with: cp .env.recommended .env
#
# SETUP REQUIREMENTS:
# 1. HAI CLI (Recommended) - Auto-configures authentication
#    - Install: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/recipes/cline/
#    - Authenticate: hai auth login
#    - This config will auto-start proxy when needed
#
# 2. HAI Desktop Application - Requires manual API key
#    - Set HAI_AUTO_START=false (see below)
#    - Start proxy from desktop app
#    - Copy API key from app settings and uncomment/set HAI_API_KEY below:
#    # HAI_API_KEY=your-api-key-from-hai-desktop-app

AI_PROVIDER=hai

# ============================================================================
# Models - EXPERIMENT-VALIDATED CONFIGURATION
# ============================================================================
# Based on experiments/003-hai-proxy-compatible/findings.md
#
# GPT-5 Mini: 91.2% accuracy, $0.02/image, 51.6s latency, score: 75.7 ⭐
# Why: Best accuracy with lowest cost. Mini models outperform full models.
AI_MODEL_OCR=gpt-5-mini

# GPT-4.1 Mini: 85.6% accuracy, $0.02/image, 39.7s latency
# Why: Cost-effective cross-provider fallback
AI_MODEL_OCR_FALLBACK=gpt-4.1-mini

# Claude Haiku: Fast, cost-effective for text operations
AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku
AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# Alternative OCR Models (tested but not recommended for production):
# - anthropic--claude-4.6-sonnet   (90.3% accuracy, $0.12/image, 5x more expensive)
# - anthropic--claude-4.6-opus     (90.2% accuracy, $0.62/image, 30x more expensive)
# - gpt-5                          (82.3% accuracy, $0.10/image, worse than mini!)
# - gpt-4.1-mini                   (85.6% accuracy, $0.02/image, faster but less accurate)

# Models NOT available in HAI proxy (discovered in experiments):
# ❌ gpt-4o - Does not exist
# ❌ gpt-4-vision-preview - Not supported

# ============================================================================
# HAI Proxy Settings
# ============================================================================
# For HAI CLI users (auto-configured auth):
HAI_AUTO_START=true
HAI_PROXY_PORT=6655

# For HAI Desktop App users (manual auth required):
# HAI_AUTO_START=false
# HAI_API_KEY=your-api-key-from-hai-desktop-app
# HAI_PROXY_PORT=6655

# ============================================================================
# OCR Quality Assessment (Enhanced Detection)
# ============================================================================
# Triggers fallback when primary OCR quality is poor
# Based on experiments/003-hai-proxy-compatible/ findings

# Uncertainty threshold: illegiblePercent + italicPercent
# Increased from 15% to 30% to account for combined metric
OCR_UNCERTAIN_THRESHOLD=30

# Consecutive illegible markers before triggering fallback
OCR_CONSECUTIVE_ILLEGIBLE_THRESHOLD=5

# Use enhanced quality check (illegible + italic markers)
# Set to true to use legacy illegible-only detection
OCR_LEGACY_QUALITY_CHECK=false

# ============================================================================
# Image Compression (GPT Models Support 20MB)
# ============================================================================
# GPT models support larger images than Claude (Claude: 5MB, GPT: 20MB)
IMAGE_COMPRESSION_ENABLED=true
IMAGE_COMPRESSION_MAX_SIZE_MB=20
IMAGE_COMPRESSION_MIN_QUALITY=70

# ============================================================================
# Handwriting Reference (Optional)
# ============================================================================
HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json

# ============================================================================
# Performance Improvements vs Previous Configuration
# ============================================================================
# Before (Claude Sonnet):  90.3% accuracy, $0.12/image, 52.6s
# After (GPT-5 Mini):      91.2% accuracy, $0.02/image, 51.6s
#
# Improvements:
# - Accuracy:  +0.9% (91.2% vs 90.3%)
# - Cost:      -83% ($0.02 vs $0.12)
# - Latency:   -1.9% (51.6s vs 52.6s)
# - Score:     +19.8% (75.7 vs 63.2)
#
# Annual Savings (10K images): $1,000/year
#
# See: experiments/003-hai-proxy-compatible/findings.md
