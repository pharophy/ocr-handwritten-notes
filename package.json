{
  "name": "handwritten-ocr-cli",
  "type": "module",
  "scripts": {
    "start": "node ./node_modules/tsx/dist/cli.mjs src/main.ts",
    "convert": "node ./node_modules/tsx/dist/cli.mjs src/convert-single.ts",
    "aggregate-actions": "node ./node_modules/tsx/dist/cli.mjs src/aggregate-actions.ts",
    "aggregate-insights": "node ./node_modules/tsx/dist/cli.mjs src/aggregate-insights.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test-ocr": "node ./node_modules/tsx/dist/cli.mjs src/cli/testOCR.ts",
    "test-ocr-suite": "node ./node_modules/tsx/dist/cli.mjs src/cli/testOCRSuite.ts",
    "experiment-ocr": "node ./node_modules/tsx/dist/cli.mjs src/cli/experimentOCR.ts",
    "advanced-experiment": "node ./node_modules/tsx/dist/cli.mjs src/cli/advancedExperiment.ts",
    "generate-experiment-summary": "node scripts/generateExperimentSummary.js"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@types/node": "^22.14.1",
    "dotenv": "^16.5.0",
    "openai": "^4.96.0",
    "openspec": "^0.0.0",
    "sharp": "^0.34.2"
  }
}
