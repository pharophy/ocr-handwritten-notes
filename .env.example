# ============================================================================
# AI Provider Configuration
# ============================================================================

# AI_PROVIDER - Choose which AI service to use for OCR and summarization
# ============================================================================
# Valid options:
#   - openai        Use OpenAI directly (requires OPENAI_API_KEY)
#   - hai-claude    Use Claude via HAI proxy (recommended for SAP employees)
#   - hai-openai    Use OpenAI via HAI proxy (for SAP employees)
#   - <not set>     Auto-detect: HAI proxy if running, otherwise OpenAI direct
#
# Default: Auto-detect (checks for HAI proxy on port 6655, falls back to OpenAI)
# AI_PROVIDER=hai-claude

# ============================================================================
# OpenAI Configuration (for AI_PROVIDER=openai)
# ============================================================================

# OPENAI_API_KEY - Your OpenAI API key for direct access
# ============================================================================
# Get your key from: https://platform.openai.com/api-keys
# Format: sk-proj-... (starts with 'sk-proj-' or 'sk-')
# Required when: AI_PROVIDER=openai OR when using fallback with no HAI proxy
# OPENAI_API_KEY=sk-proj-...

# ============================================================================
# HAI Proxy Configuration (for AI_PROVIDER=hai-claude or hai-openai)
# ============================================================================
# HAI (Hyperspace AI) proxy provides free access to Claude and OpenAI
# through SAP corporate infrastructure.
# Documentation: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/

# HAI_AUTO_START - Automatically start HAI proxy if not running
# ============================================================================
# Valid options:
#   - true     Auto-start proxy when needed (launches 'hai proxy start --headless')
#   - false    Don't auto-start; user must start manually
#
# Default: true
# Note: Requires HAI CLI installed (https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/recipes/cline/)
HAI_AUTO_START=true

# HAI_PROXY_PORT - Port where HAI proxy listens
# ============================================================================
# Valid options: Any available port number (1024-65535)
# Default: 6655 (HAI proxy default)
# Note: Must match the port HAI proxy is configured to use
HAI_PROXY_PORT=6655

# ANTHROPIC_BASE_URL - Base URL for Anthropic API via HAI proxy
# ============================================================================
# Valid options:
#   - http://localhost:6655/anthropic/     Local HAI proxy (default)
#   - http://localhost:<port>/anthropic/   Custom port
#   - <not set>                            Auto-generated from HAI_PROXY_PORT
#
# Default: http://localhost:6655/anthropic/
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/

# ANTHROPIC_AUTH_TOKEN - Authentication token for HAI proxy
# ============================================================================
# Valid options: Token string (usually auto-configured by HAI CLI)
# Default: Auto-configured by HAI proxy
# Note: Rarely needs to be set manually; HAI manages this automatically
# Alternative: HAI_API_KEY can be used instead
# ANTHROPIC_AUTH_TOKEN=

# ============================================================================
# Model Selection (optional - uses smart defaults if not set)
# ============================================================================
# Specify which AI model to use for each operation type.
# Different models have different capabilities and costs.

# AI_MODEL_OCR - Model for handwriting OCR (requires vision capability)
# ============================================================================
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4o                Latest GPT-4 with vision (default, recommended)
#   - gpt-4-turbo           GPT-4 Turbo with vision
#   - gpt-4-vision-preview  GPT-4 Vision preview
#   Full list: https://platform.openai.com/docs/models
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - anthropic--claude-4.5-sonnet   Claude 3.5 Sonnet (default, best for handwriting)
#   - anthropic--claude-opus-4       Claude 3 Opus (highest accuracy)
#   - anthropic--claude-4.5-haiku    Claude 3.5 Haiku (faster, lower cost)
#   Note: Model names in HAI use '--' separator
#   Full list: Run 'hai models' or see https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/
#
# Default: gpt-4o (OpenAI) or anthropic--claude-4.5-sonnet (HAI)
# AI_MODEL_OCR=anthropic--claude-4.5-sonnet

# AI_MODEL_SUMMARIZATION - Model for generating meeting summaries
# ============================================================================
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4o-mini           Optimized for speed and cost (default, recommended)
#   - gpt-4o                Latest GPT-4 (more capable but higher cost)
#   - gpt-3.5-turbo         Fastest, lowest cost
#   Full list: https://platform.openai.com/docs/models
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - anthropic--claude-4.5-haiku    Claude 3.5 Haiku (default, fast and cost-effective)
#   - anthropic--claude-4.5-sonnet   Claude 3.5 Sonnet (more capable)
#   - anthropic--claude-opus-4       Claude 3 Opus (highest quality)
#
# Default: gpt-4o-mini (OpenAI) or anthropic--claude-4.5-haiku (HAI)
# AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku

# AI_MODEL_VALIDATION - Model for OCR quality validation
# ============================================================================
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4o-mini           Optimized for speed and cost (default, recommended)
#   - gpt-4o                Latest GPT-4 (more thorough validation)
#   - gpt-3.5-turbo         Fastest, lowest cost
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - anthropic--claude-4.5-haiku    Claude 3.5 Haiku (default, fast validation)
#   - anthropic--claude-4.5-sonnet   Claude 3.5 Sonnet (more thorough)
#
# Default: gpt-4o-mini (OpenAI) or anthropic--claude-4.5-haiku (HAI)
# AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# ============================================================================
# Handwriting Reference Configuration
# ============================================================================

# HANDWRITING_REFERENCE_ENABLED - Enable personalized handwriting recognition
# ============================================================================
# Valid options:
#   - true     Load handwriting reference for improved OCR accuracy (default)
#   - false    Skip handwriting reference, use standard OCR
#
# Default: true
# Note: Provides context about your writing style, acronyms, and terminology
HANDWRITING_REFERENCE_ENABLED=true

# HANDWRITING_REFERENCE_FILE - Path to handwriting reference JSON file
# ============================================================================
# Valid options: Any valid file path (absolute or relative to project root)
# Default: ./handwriting-reference.json
# Note: File should contain reference words, glossary, and OCR validation settings
# See handwriting-reference.json for format and examples
# HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
