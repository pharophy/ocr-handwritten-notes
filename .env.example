# AI Provider Configuration
# Choose one of: openai, hai-claude, hai-openai
# If not set, will auto-detect based on available configuration
# AI_PROVIDER=hai-claude

# OpenAI Configuration (for direct OpenAI access)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# HAI Proxy Configuration (for SAP employees)
# HAI proxy provides free access to Claude and OpenAI through corporate infrastructure
# HAI_AUTO_START=true                # Auto-start HAI proxy if not running (default: true)
# HAI_PROXY_PORT=6655               # Port for HAI proxy (default: 6655)
# ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
# ANTHROPIC_AUTH_TOKEN=             # Usually auto-configured by HAI

# Model Selection (optional, provider-specific defaults used if not set)
# For OpenAI:
#   AI_MODEL_OCR=gpt-4o
#   AI_MODEL_SUMMARIZATION=gpt-4o-mini
#   AI_MODEL_VALIDATION=gpt-4o-mini
#
# For Claude via HAI:
#   AI_MODEL_OCR=anthropic--claude-4.5-sonnet
#   AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku
#   AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# Handwriting Reference Configuration
HANDWRITING_REFERENCE_ENABLED=true
# HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
