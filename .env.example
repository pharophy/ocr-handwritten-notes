# ============================================================================
# AI Provider Configuration
# ============================================================================
# Supported providers:
#   - openai       Direct OpenAI API
#   - anthropic    Direct Anthropic API or Anthropic-compatible endpoint
#
# If AI_PROVIDER is not set, the app may infer the provider when exactly one
# provider credential is present. Set AI_PROVIDER explicitly when both OpenAI
# and Anthropic credentials are available.

AI_PROVIDER=openai

# ============================================================================
# OpenAI Direct Configuration
# ============================================================================
# Required when AI_PROVIDER=openai.
# Get a key from: https://platform.openai.com/api-keys

# OPENAI_API_KEY=sk-proj-...

# Optional OpenAI model overrides.
# AI_MODEL_OCR=gpt-5-mini
# AI_MODEL_SUMMARIZATION=gpt-5-mini
# AI_MODEL_VALIDATION=gpt-5-mini
# AI_MODEL_OCR_FALLBACK=gpt-4.1-mini

# Backward-compatible OpenAI-specific overrides.
# OPENAI_MODEL_OCR=gpt-5-mini
# OPENAI_MODEL_SUMMARIZATION=gpt-5-mini
# OPENAI_MODEL_VALIDATION=gpt-5-mini

# ============================================================================
# Anthropic Direct Configuration
# ============================================================================
# Required when AI_PROVIDER=anthropic. Use either ANTHROPIC_API_KEY or
# ANTHROPIC_AUTH_TOKEN. ANTHROPIC_BASE_URL is optional and is useful for
# Anthropic-compatible gateways.

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional Anthropic model overrides. Use provider-native Anthropic model IDs,
# not legacy prefixed aliases.
# AI_MODEL_OCR=claude-sonnet-4-20250514
# AI_MODEL_SUMMARIZATION=claude-3-5-haiku-20241022
# AI_MODEL_VALIDATION=claude-3-5-haiku-20241022
# AI_MODEL_OCR_FALLBACK=none

# ============================================================================
# OCR Quality Thresholds
# ============================================================================

# OCR_UNCERTAIN_THRESHOLD=30
# OCR_ILLEGIBLE_THRESHOLD=15
# OCR_CONSECUTIVE_ILLEGIBLE_THRESHOLD=5
# OCR_LEGACY_QUALITY_CHECK=false
# OCR_MIN_LENGTH_THRESHOLD=50
# OCR_MIN_IMAGE_SIZE=100000

# ============================================================================
# Image Compression Configuration
# ============================================================================

IMAGE_COMPRESSION_ENABLED=true
IMAGE_COMPRESSION_MAX_SIZE_MB=20
IMAGE_COMPRESSION_MIN_QUALITY=70

# ============================================================================
# Handwriting Reference Configuration
# ============================================================================

HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
