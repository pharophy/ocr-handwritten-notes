# ============================================================================
# AI Provider Configuration
# ============================================================================

# AI_PROVIDER - Choose which AI service to use for OCR and summarization
# ============================================================================
# Valid options:
#   - openai        Use OpenAI directly (requires OPENAI_API_KEY)
#   - hai-claude    Use Claude via HAI proxy (recommended for SAP employees)
#   - hai-openai    Use OpenAI via HAI proxy (for SAP employees)
#   - <not set>     Auto-detect: HAI proxy if running, otherwise OpenAI direct
#
# Default: Auto-detect (checks for HAI proxy on port 6655, falls back to OpenAI)
# AI_PROVIDER=hai-claude

# ============================================================================
# OpenAI Configuration (for AI_PROVIDER=openai)
# ============================================================================

# OPENAI_API_KEY - Your OpenAI API key for direct access
# ============================================================================
# Get your key from: https://platform.openai.com/api-keys
# Format: sk-proj-... (starts with 'sk-proj-' or 'sk-')
# Required when: AI_PROVIDER=openai OR when using fallback with no HAI proxy
# OPENAI_API_KEY=sk-proj-...

# ============================================================================
# HAI Proxy Configuration (for AI_PROVIDER=hai-claude or hai-openai)
# ============================================================================
# HAI (Hyperspace AI) proxy provides free access to Claude and OpenAI
# through SAP corporate infrastructure.
# Documentation: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/
#
# SETUP METHODS:
# 1. HAI CLI (Recommended) - Auto-configures authentication
#    Install: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/recipes/cline/
#    Authenticate: hai auth login
#    Start proxy: hai proxy start --headless
#
# 2. HAI Desktop Application - Requires manual API key configuration
#    After starting proxy from desktop app, copy API key from app settings
#    and set HAI_API_KEY below (see ANTHROPIC_AUTH_TOKEN section)

# HAI_AUTO_START - Automatically start HAI proxy if not running
# ============================================================================
# Valid options:
#   - true     Auto-start proxy when needed (launches 'hai proxy start --headless')
#   - false    Don't auto-start; user must start manually
#
# Default: true
# Note: Requires HAI CLI installed. For HAI Desktop App users, set to false
#       and start proxy from the desktop application instead.
HAI_AUTO_START=true

# HAI_PROXY_PORT - Port where HAI proxy listens
# ============================================================================
# Valid options: Any available port number (1024-65535)
# Default: 6655 (HAI proxy default)
# Note: Must match the port HAI proxy is configured to use
HAI_PROXY_PORT=6655

# ANTHROPIC_BASE_URL - Base URL for Anthropic API via HAI proxy
# ============================================================================
# Valid options:
#   - http://localhost:6655/anthropic/     Local HAI proxy (default)
#   - http://localhost:<port>/anthropic/   Custom port
#   - <not set>                            Auto-generated from HAI_PROXY_PORT
#
# Default: http://localhost:6655/anthropic/
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/

# ANTHROPIC_AUTH_TOKEN - Authentication token for HAI proxy
# ============================================================================
# SETUP METHOD 1: HAI CLI (Recommended - Auto-configured)
#   - Automatically configured by HAI CLI after running 'hai auth login'
#   - No manual configuration needed
#   - Token is managed transparently by HAI CLI
#
# SETUP METHOD 2: HAI Desktop Application (Requires Manual Setup)
#   - Open HAI Desktop Application
#   - Start the proxy from the app
#   - Copy the API key from app settings (usually under Settings or API section)
#   - Uncomment and set HAI_API_KEY below with the copied key:
#
# HAI_API_KEY=your-api-key-from-hai-desktop-app
#
# IMPORTANT: When using HAI Desktop App, you MUST set HAI_API_KEY manually.
# The desktop app does not auto-configure this like the CLI does.
#
# Valid options: Token string
# Default: Auto-configured by HAI CLI (only when using CLI, not desktop app)
# Alternative: HAI_API_KEY can be used instead of ANTHROPIC_AUTH_TOKEN
# Both work interchangeably - use whichever is set
# ANTHROPIC_AUTH_TOKEN=

# ============================================================================
# Model Selection (optional - uses smart defaults if not set)
# ============================================================================
# Specify which AI model to use for each operation type.
# Different models have different capabilities and costs.

# AI_MODEL_OCR - Model for handwriting OCR (requires vision capability)
# ============================================================================
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4o                Latest GPT-4 with vision (default, recommended)
#   - gpt-4-turbo           GPT-4 Turbo with vision
#   - gpt-4-vision-preview  GPT-4 Vision preview
#   Full list: https://platform.openai.com/docs/models
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - anthropic--claude-4.5-sonnet   Claude 3.5 Sonnet (default, best for handwriting)
#   - anthropic--claude-opus-4       Claude 3 Opus (highest accuracy)
#   - anthropic--claude-4.5-haiku    Claude 3.5 Haiku (faster, lower cost)
#   Note: Model names in HAI use '--' separator
#   Full list: Run 'hai models' or see https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/
#
# Default: gpt-4o (OpenAI) or anthropic--claude-4.5-sonnet (HAI)
# AI_MODEL_OCR=anthropic--claude-4.5-sonnet

# AI_MODEL_SUMMARIZATION - Model for generating meeting summaries
# ============================================================================
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4o-mini           Optimized for speed and cost (default, recommended)
#   - gpt-4o                Latest GPT-4 (more capable but higher cost)
#   - gpt-3.5-turbo         Fastest, lowest cost
#   Full list: https://platform.openai.com/docs/models
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - anthropic--claude-4.5-haiku    Claude 3.5 Haiku (default, fast and cost-effective)
#   - anthropic--claude-4.5-sonnet   Claude 3.5 Sonnet (more capable)
#   - anthropic--claude-opus-4       Claude 3 Opus (highest quality)
#
# Default: gpt-4o-mini (OpenAI) or anthropic--claude-4.5-haiku (HAI)
# AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku

# AI_MODEL_VALIDATION - Model for OCR quality validation
# ============================================================================
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4o-mini           Optimized for speed and cost (default, recommended)
#   - gpt-4o                Latest GPT-4 (more thorough validation)
#   - gpt-3.5-turbo         Fastest, lowest cost
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - anthropic--claude-4.5-haiku    Claude 3.5 Haiku (default, fast validation)
#   - anthropic--claude-4.5-sonnet   Claude 3.5 Sonnet (more thorough)
#
# Default: gpt-4o-mini (OpenAI) or anthropic--claude-4.5-haiku (HAI)
# AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# AI_MODEL_OCR_FALLBACK - Fallback model when primary OCR quality is poor
# ============================================================================
# Automatically retry OCR with a different model when the primary model produces
# low-quality results (high illegible markers, very short output, etc.)
#
# HOW IT WORKS:
# 1. Primary OCR runs with your configured model
# 2. Quality assessment checks for poor indicators:
#    - >15% illegible markers (configurable via OCR_ILLEGIBLE_THRESHOLD)
#    - 5+ consecutive illegible markers
#    - Very short output (<50 chars for large images)
# 3. If poor quality detected, automatically retries with fallback model
# 4. Returns the fallback result (typically much better quality)
#
# REQUIREMENTS:
# - For cross-provider fallback (Claude ↔ OpenAI), HAI proxy must be running
# - Both providers accessible through same proxy (automatic with HAI)
# - No additional configuration needed - provider switching is automatic
#
# For OpenAI (AI_PROVIDER=openai or hai-openai):
#   - gpt-4.1-mini          GPT-4.1 Mini (recommended fallback, good accuracy)
#   - gpt-4.1               GPT-4.1 (higher accuracy, slower)
#   - gpt-4o                Latest GPT-4 with vision
#
# For Claude via HAI (AI_PROVIDER=hai-claude):
#   - gpt-4.1-mini          Cross-provider fallback to OpenAI (RECOMMENDED)
#   - anthropic--claude-4.6-sonnet   Claude 4.6 Sonnet (perfect for some styles)
#   - anthropic--claude-4.5-opus     Claude 3.5 Opus (high capability)
#
# Special values:
#   - none or ""            Disable fallback (use primary result regardless of quality)
#   - <not set>             Use default: gpt-4.1-mini
#
# Default: gpt-4.1-mini (cross-provider fallback for best coverage)
#
# Recommended combinations based on production testing:
#   - Primary: Claude 4.6 Sonnet → Fallback: GPT-4.1 Mini (BEST - 100% to 0% illegible)
#   - Primary: GPT-4o → Fallback: Claude 4.6 Sonnet
#
# Real-world example (Amir 04-01.jpeg):
#   - Primary (Claude): 26% illegible → 112 *[illegible]* markers
#   - Fallback (GPT-4.1 Mini): 0% illegible → Clean, readable output
AI_MODEL_OCR_FALLBACK=gpt-4.1-mini

# ============================================================================
# OCR Quality Thresholds (Optional - Fine-tune fallback behavior)
# ============================================================================

# OCR_ILLEGIBLE_THRESHOLD - Trigger fallback when illegible % exceeds this
# ============================================================================
# Valid options: Any number between 0-100
# Default: 15 (trigger fallback if >15% of words are illegible)
# Lower = more aggressive fallback, fewer poor results
# Higher = more conservative, fallback only on severe quality issues
# Recommended: 15 (based on production testing where 26% was clearly poor)
# OCR_ILLEGIBLE_THRESHOLD=15

# OCR_CONSECUTIVE_ILLEGIBLE_THRESHOLD - Trigger fallback on consecutive illegibles
# ============================================================================
# Valid options: Any positive integer
# Default: 1 (trigger if ANY occurrence of 5+ consecutive illegible markers)
# Detects complete failure to read a section of the image
# OCR_CONSECUTIVE_ILLEGIBLE_THRESHOLD=1

# OCR_MIN_LENGTH_THRESHOLD - Minimum output length for large images
# ============================================================================
# Valid options: Any positive integer (characters)
# Default: 50 (trigger fallback if output <50 chars for large images)
# Detects when OCR produces suspiciously short output
# OCR_MIN_LENGTH_THRESHOLD=50

# OCR_MIN_IMAGE_SIZE - Image size threshold for length check
# ============================================================================
# Valid options: Any positive integer (bytes)
# Default: 100000 (100KB - only check length for images larger than this)
# Small images naturally have short output, so we only check large images
# OCR_MIN_IMAGE_SIZE=100000

# ============================================================================
# Handwriting Reference Configuration
# ============================================================================

# HANDWRITING_REFERENCE_ENABLED - Enable personalized handwriting recognition
# ============================================================================
# Valid options:
#   - true     Load handwriting reference for improved OCR accuracy (default)
#   - false    Skip handwriting reference, use standard OCR
#
# Default: true
# Note: Provides context about your writing style, acronyms, and terminology
HANDWRITING_REFERENCE_ENABLED=true

# HANDWRITING_REFERENCE_FILE - Path to handwriting reference JSON file
# ============================================================================
# Valid options: Any valid file path (absolute or relative to project root)
# Default: ./handwriting-reference.json
# Note: File should contain reference words, glossary, and OCR validation settings
# See handwriting-reference.json for format and examples
# HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
