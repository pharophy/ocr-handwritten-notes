# ============================================================================
# HAI Proxy Configuration - Claude Primary (Higher Cost Alternative)
# ============================================================================
# Based on experiments/003-hai-proxy-compatible/ findings
# Claude 4.6 Sonnet: 90.3% accuracy at $0.12/image
#
# ⚠️ Note: GPT-5 Mini achieves BETTER accuracy (91.2%) at 83% lower cost ($0.02)
#    This configuration is for users who prefer Claude models
#
# Use with: cp .env.proxy.claude .env
#
# SETUP REQUIREMENTS:
# 1. HAI CLI (Recommended) - Auto-configures authentication
#    - Install: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/recipes/cline/
#    - Authenticate: hai auth login
#    - This config will auto-start proxy when needed
#
# 2. HAI Desktop Application - Requires manual API key
#    - Set HAI_AUTO_START=false (see below)
#    - Start proxy from desktop app
#    - Copy API key from app settings and uncomment/set HAI_API_KEY below:
#    # HAI_API_KEY=your-api-key-from-hai-desktop-app

AI_PROVIDER=hai

# ============================================================================
# Models - Claude Primary Configuration
# ============================================================================
# Based on experiments/003-hai-proxy-compatible/findings.md

# Primary OCR: Claude 4.6 Sonnet
# - 90.3% accuracy (0.9% lower than GPT-5 Mini)
# - $0.12/image (6x more expensive than GPT-5 Mini)
# - 52.6s latency
# - 0% uncertainty markers
# - Score: 63.2/100
AI_MODEL_OCR=anthropic--claude-4.6-sonnet

# Fallback OCR: GPT-5 Mini (Cross-provider fallback)
# - 91.2% accuracy (actually better than primary!)
# - $0.02/image
# - Different architecture handles different handwriting styles
AI_MODEL_OCR_FALLBACK=gpt-5-mini

# Summarization: Claude Haiku (fast, cost-effective)
AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku
AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# ============================================================================
# Alternative Claude Models (tested but not recommended)
# ============================================================================
# Claude 4.6 Opus:
# - 90.2% accuracy (only 0.1% worse than Sonnet)
# - $0.62/image (5x more expensive than Sonnet)
# - 30.5s latency (fastest but not worth the cost)
# - Score: 63.1/100
# ❌ Not recommended: Similar accuracy at 5x the cost

# Older Claude models (not tested in experiments):
# - anthropic--claude-4.5-sonnet
# - anthropic--claude-4.5-opus
# - anthropic--claude-4.5-haiku (used for summarization only)
# - anthropic--claude-4-sonnet

# ============================================================================
# Why Not Use GPT-5 Mini? (Experiment Results)
# ============================================================================
# Experiment 003 showed GPT-5 Mini is objectively better:
#
# GPT-5 Mini:      91.2% accuracy at $0.02/image, score: 75.7 ✅
# Claude Sonnet:   90.3% accuracy at $0.12/image, score: 63.2
#
# However, you may prefer Claude for:
# - Organizational preference for Anthropic models
# - Specific handwriting style compatibility
# - Existing Claude-based workflows
#
# See: experiments/003-hai-proxy-compatible/findings.md

# ============================================================================
# Performance vs Recommended Configuration
# ============================================================================
# Recommended (GPT-5 Mini): 91.2% accuracy, $0.02/image, 51.6s, score: 75.7
# This Config (Claude):     90.3% accuracy, $0.12/image, 52.6s, score: 63.2
#
# Tradeoffs:
# - Accuracy:  -0.9% (91.2% → 90.3%)
# - Cost:      +500% ($0.02 → $0.12)
# - Latency:   +1.9% (51.6s → 52.6s)
# - Score:     -16.5% (75.7 → 63.2)
#
# Annual Additional Cost (10K images): +$1,000/year

# ============================================================================
# HAI Proxy Settings
# ============================================================================
# For HAI CLI users (auto-configured auth):
HAI_AUTO_START=true
HAI_PROXY_PORT=6655

# For HAI Desktop App users (manual auth required):
# HAI_AUTO_START=false
# HAI_API_KEY=your-api-key-from-hai-desktop-app
# HAI_PROXY_PORT=6655

# Note: HAI proxy automatically routes to the correct endpoint based on model name
# - anthropic--* models → /anthropic/ endpoint
# - gpt-* models → /openai/v1 endpoint

# ============================================================================
# OCR Quality Assessment (Enhanced Detection)
# ============================================================================
# Triggers fallback when primary OCR quality is poor
OCR_UNCERTAIN_THRESHOLD=30                   # Combined illegible + italic markers
OCR_CONSECUTIVE_ILLEGIBLE_THRESHOLD=5       # Consecutive illegibles
OCR_LEGACY_QUALITY_CHECK=false               # Use enhanced detection

# ============================================================================
# Image Compression (Claude Has 5MB Limit)
# ============================================================================
IMAGE_COMPRESSION_ENABLED=true
IMAGE_COMPRESSION_MAX_SIZE_MB=5              # Claude's limit (GPT supports 20MB)
IMAGE_COMPRESSION_MIN_QUALITY=70

# ============================================================================
# Handwriting Reference (Optional)
# ============================================================================
HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
