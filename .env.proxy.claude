# ============================================================================
# HAI Proxy Configuration (Claude + OpenAI)
# ============================================================================
# Pre-configured for HAI proxy with automatic model routing
# Use with: cp .env.proxy.claude .env
#
# SETUP REQUIREMENTS:
# 1. HAI CLI (Recommended) - Auto-configures authentication
#    - Install: https://ai-docs.portal.hyperspace.tools.sap/llm-proxy/recipes/cline/
#    - Authenticate: hai auth login
#    - This config will auto-start proxy when needed
#
# 2. HAI Desktop Application - Requires manual API key
#    - Set HAI_AUTO_START=false (see below)
#    - Start proxy from desktop app
#    - Copy API key from app settings and uncomment/set HAI_API_KEY below:
#    # HAI_API_KEY=your-api-key-from-hai-desktop-app

AI_PROVIDER=hai

# ============================================================================
# Models (HAI auto-routes based on model name)
# ============================================================================
# Recommended models for each operation:
AI_MODEL_OCR=anthropic--claude-4.6-sonnet
AI_MODEL_SUMMARIZATION=anthropic--claude-4.5-haiku
AI_MODEL_VALIDATION=anthropic--claude-4.5-haiku

# Automatic OCR Fallback (cross-provider for best coverage)
AI_MODEL_OCR_FALLBACK=gpt-4.1-mini

# Available Claude models for OCR (vision required):
# - anthropic--claude-4.6-sonnet   (latest, recommended)
# - anthropic--claude-4.6-opus     (highest accuracy)
# - anthropic--claude-4.5-sonnet   (excellent for handwriting)
# - anthropic--claude-4.5-opus     (high capability)
# - anthropic--claude-4.5-haiku    (fast, cost-effective)
# - anthropic--claude-4-sonnet     (previous generation)

# ============================================================================
# HAI Proxy Settings
# ============================================================================
# For HAI CLI users (auto-configured auth):
HAI_AUTO_START=true
HAI_PROXY_PORT=6655

# For HAI Desktop App users (manual auth required):
# HAI_AUTO_START=false
# HAI_API_KEY=your-api-key-from-hai-desktop-app
# HAI_PROXY_PORT=6655

# Note: HAI proxy automatically routes to the correct endpoint based on model name
# - anthropic--* models → /anthropic/ endpoint
# - gpt-* models → /openai/v1 endpoint

# ============================================================================
# Handwriting Reference
# ============================================================================
HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
