# ============================================================================
# OpenAI Direct Configuration (No Proxy)
# ============================================================================
# Pre-configured for testing OpenAI models directly (not through HAI proxy)
# Use with: cp .env.proxy.openai-direct .env
# IMPORTANT: You must set your OPENAI_API_KEY below

AI_PROVIDER=openai

# ============================================================================
# OpenAI Models (Latest from OpenAI API)
# ============================================================================
# Recommended models for each operation:
AI_MODEL_OCR=gpt-5
AI_MODEL_SUMMARIZATION=gpt-5-mini
AI_MODEL_VALIDATION=gpt-5-mini

# Automatic OCR Fallback (cross-provider not available with direct OpenAI)
# Use another OpenAI model as fallback:
AI_MODEL_OCR_FALLBACK=gpt-4.1-mini

# Available OpenAI models for OCR (vision required):
# - gpt-5            (latest, best accuracy)
# - gpt-5-mini       (fast, cost-effective)
# - gpt-4.1          (high capability)
# - gpt-4.1-mini     (balanced option)

# ============================================================================
# OpenAI API Configuration
# ============================================================================
# REQUIRED: Set your OpenAI API key here
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Disable HAI proxy auto-start since we're using direct API
HAI_AUTO_START=false

# ============================================================================
# Handwriting Reference
# ============================================================================
HANDWRITING_REFERENCE_ENABLED=true
HANDWRITING_REFERENCE_FILE=./handwriting-reference.json
